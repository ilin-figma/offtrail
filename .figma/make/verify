#!/bin/bash
set -e

timeout=120
elapsed=0
interval=2
url="http://localhost:8000"

while [ $elapsed -lt $timeout ]; do
  if curl -s -o /dev/null -w '' "$url" 2>/dev/null; then
    echo "Dev server is ready at $url"
    exit 0
  fi
  sleep $interval
  elapsed=$((elapsed + interval))
done

echo "Timed out waiting for dev server at $url after ${timeout}s"
exit 1
